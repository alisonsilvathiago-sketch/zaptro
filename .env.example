# Copie para `.env.local` (front) ou configure no painel de deploy (Vercel, etc.).

# URL pública da API de e-mail (SendGrid no `server/`). Em dev com Vite: `/zaptro-mail-api` (proxy → porta 8787).
# Em produção: `https://mail.seudominio.com` (sem barra final).
VITE_ZAPTRO_MAIL_API_URL=

# Supabase (já usados no projeto; nomes típicos Vite)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# VITE_SUPABASE_ZAPTRO_URL=
# VITE_SUPABASE_ZAPTRO_ANON_KEY=

# Variáveis do serviço Node de e-mail: ver `server/env.sample` (SENDGRID_API_KEY, SUPABASE_URL, etc.).
